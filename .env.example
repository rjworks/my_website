# Vercel KV — used by /api/hello and /api/blogs to persist content.
# Pull real values with `vercel env pull .env.local` once KV is provisioned.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: gate mutating requests (POST/PATCH/DELETE) on /api/hello and /api/blogs.
# If unset, those endpoints are open — set this before deploying publicly.
HELLO_API_SECRET=
BLOG_API_SECRET=

# Used by mcp-server/blogs.ts to reach the site's blog API.
# Point at your deployed URL to manage production blogs, or leave as
# localhost to manage a local dev server (`npm run dev`).
BLOG_API_URL=http://localhost:3000
